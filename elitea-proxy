#!/usr/bin/env bash
# Wrapper for elitea-proxy using uv
# This script ensures it runs in the project directory with the correct environment.

PROJECT_DIR="/Users/mlevin/software/elitea-proxy"
export ELITEA_PROXY_CALLER_CWD="$PWD"
cd "$PROJECT_DIR" || exit 1

# Check if uv is installed
if ! command -v uv &> /dev/null; then
    echo "Error: 'uv' is not installed or not in PATH."
    exit 1
fi

exec uv run python elitea-proxy.py "$@"
